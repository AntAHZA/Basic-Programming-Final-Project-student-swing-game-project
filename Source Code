  import java.io.*;
import java.util.*;

public class DatabaseManager {
    private static final String FILE_NAME = "database.txt";

    // Simulates database initialization
    public static boolean initializeFileDatabase() {
        File file = new File(FILE_NAME);
        if (!file.exists()) {
            try {
                file.createNewFile();
                // Inject our default testing player into the text file!
                savePlayerData(new Player("player1", "pass123", 0, 0, 0, 0));
                System.out.println("File database initialized successfully!");
            } catch (IOException e) {
                System.err.println("Failed to create file database.");
                return false;
            }
        }
        return true;
    }

    // Helper to read all players from the text file
    public static List<Player> getAllPlayers() {
        List<Player> players = new ArrayList<>();
        File file = new File(FILE_NAME);
        if (!file.exists()) initializeFileDatabase();

        try (BufferedReader br = new BufferedReader(new FileReader(file))) {
            String line;
            while ((line = br.readLine()) != null) {
                String[] data = line.split(",");
                if (data.length == 6) {
                    players.add(new Player(
                        data[0], // username
                        data[1], // password
                        Integer.parseInt(data[2]), // wins
                        Integer.parseInt(data[3]), // losses
                        Integer.parseInt(data[4]), // draws
                        Integer.parseInt(data[5])  // score
                    ));
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        return players;
    }

    // Helper to save or update a player in the text file
    public static void savePlayerData(Player playerToSave) {
        List<Player> players = getAllPlayers();
        boolean found = false;

        // Update player data if they already exist
        for (int i = 0; i < players.size(); i++) {
            if (players.get(i).getUsername().equalsIgnoreCase(playerToSave.getUsername())) {
                players.set(i, playerToSave);
                found = true;
                break;
            }
        }

        if (!found) {
            players.add(playerToSave);
        }

        // Rewrite the file with updated values
        try (PrintWriter pw = new PrintWriter(new FileWriter(FILE_NAME))) {
            for (Player p : players) {
                pw.println(p.getUsername() + "," + p.getPassword() + "," + 
                           p.getWins() + "," + p.getLosses() + "," + 
                           p.getDraws() + "," + p.getScore());
            }
        } catch (IOException e) {
            e.printStackTrace();
        }
    }
}
