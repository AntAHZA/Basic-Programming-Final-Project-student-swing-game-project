public class TopScorersFrame extends JFrame {
    // 1. DECLARE IT HERE AT THE TOP OF THE CLASS
    private DefaultTableModel tableModel; 
    private JTable table;

    public TopScorersFrame() {
        setTitle("Tic-Tac-Toe - Top Scorers Leaderboard");
        setSize(500, 350);
        setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
        setLocationRelativeTo(null);
        setLayout(new BorderLayout());

        // Define column headers
        String[] columns = {"Rank", "Username", "Wins", "Losses", "Draws", "Total Score"};
        
        // 2. INITIALIZE IT HERE INSIDE THE CONSTRUCTOR
        tableModel = new DefaultTableModel(columns, 0); 
        table = new JTable(tableModel);

        // Customize table visuals slightly
        table.setFont(new Font("Arial", Font.PLAIN, 14));
        table.setRowHeight(25);
        JScrollPane scrollPane = new JScrollPane(table);
        add(scrollPane, BorderLayout.CENTER);

        // --- BACK TO MENU BUTTON ---
        JButton backButton = new JButton("Back to Main Menu");
        backButton.setFont(new Font("Arial", Font.BOLD, 14));
        backButton.addActionListener(e -> {
            // Re-fetch database info to safely drop back into the menu
            List<Player> players = DatabaseManager.getAllPlayers();
            Player defaultPlayer = players.isEmpty() ? new Player("player1", "pass123", 0, 0, 0, 0) : players.get(0);
            new MainMenuFrame(defaultPlayer).setVisible(true);
            dispose();
        });
        add(backButton, BorderLayout.SOUTH);

        // 3. LOAD THE DATA FROM YOUR FILE ENGINE
        loadLeaderboardData(); 
    }

    private void loadLeaderboardData() {
        List<Player> players = DatabaseManager.getAllPlayers();

        // Sort players by score in descending order
        players.sort((p1, p2) -> Integer.compare(p2.getScore(), p1.getScore()));

        int rank = 1;
        // Load up to the top 5 players into the visual table
        for (Player p : players) {
            if (rank > 5) break;
            tableModel.addRow(new Object[]{
                rank + "th", 
                p.getUsername(), 
                p.getWins(), 
                p.getLosses(), 
                p.getDraws(), 
                p.getScore()
            });
            rank++;
        }
    }
}
