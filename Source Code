  import java.util.Random;

public class GameLogic {
	private char[][] board;
    private char playerSymbol;
    private char computerSymbol;
    private Random random;

    public GameLogic() {
        board = new char[3][3];
        playerSymbol = 'X';    // You play as X
        computerSymbol = 'O';  // Computer plays as O
        random = new Random();
        resetBoard();
    }

    // Clears the 3x3 board grid for a fresh game
    public void resetBoard() {
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                board[i][j] = ' ';
            }
        }
    }

    // Attempts to place a move. Returns true if successful.
    public boolean makeMove(int row, int col, char symbol) {
        if (row >= 0 && row < 3 && col >= 0 && col < 3 && board[row][col] == ' ') {
            board[row][col] = symbol;
            return true;
        }
        return false;
    }

    // Handles the computer's turn by finding a random empty spot
    public int[] makeComputerMove() {
        int emptyCount = 0;
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                if (board[i][j] == ' ') emptyCount++;
            }
        }

        if (emptyCount == 0) return null; // No moves left

        while (true) {
            int row = random.nextInt(3);
            int col = random.nextInt(3);
            if (makeMove(row, col, computerSymbol)) {
                return new int[]{row, col}; // Returns where the computer moved
            }
        }
    }

    // Checks the board to see if the given symbol won
    public boolean checkWin(char symbol) {
        // Check rows and columns
        for (int i = 0; i < 3; i++) {
            if (board[i][0] == symbol && board[i][1] == symbol && board[i][2] == symbol) return true;
            if (board[0][i] == symbol && board[1][i] == symbol && board[2][i] == symbol) return true;
        }
        // Check diagonals
        if (board[0][0] == symbol && board[1][1] == symbol && board[2][2] == symbol) return true;
        if (board[0][2] == symbol && board[1][1] == symbol && board[2][0] == symbol) return true;

        return false;
    }

    // Checks if the board is completely full (Draw)
    public boolean isBoardFull() {
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                if (board[i][j] == ' ') return false;
            }
        }
        return true;
    }

    public char getPlayerSymbol() { return playerSymbol; }
    public char getComputerSymbol() { return computerSymbol; }
    public char[][] getBoard() { return board; }

}
