  import java.util.List;

public class PlayerService {

    public Player login(String username, String password) {
        // Fetch all accounts from the text file database
        List<Player> players = DatabaseManager.getAllPlayers();
        
        for (Player p : players) {
            if (p.getUsername().equals(username) && p.getPassword().equals(password)) {
                return p; // Found a match!
            }
        }
        return null; // Login failed
    }

    public boolean register(String username, String password) {
        List<Player> players = DatabaseManager.getAllPlayers();
        
        for (Player p : players) {
            if (p.getUsername().equalsIgnoreCase(username)) {
                return false; // Username already taken
            }
        }

        // Create new player and save to file
        Player newPlayer = new Player(username, password, 0, 0, 0, 0);
        DatabaseManager.savePlayerData(newPlayer);
        return true;
    }

    public void updateStatistics(Player player, String outcome) {
        if (outcome.equalsIgnoreCase("win")) {
            player.setWins(player.getWins() + 1);
            player.setScore(player.getScore() + 10);
        } else if (outcome.equalsIgnoreCase("loss")) {
            player.setLosses(player.getLosses() + 1);
            player.setScore(Math.max(0, player.getScore() - 5)); // Don't go below 0
        } else if (outcome.equalsIgnoreCase("draw")) {
            player.setDraws(player.getDraws() + 1);
            player.setScore(player.getScore() + 2);
        }

        // Save updated data straight back to the file
        DatabaseManager.savePlayerData(player);
    }
}
