public class GameFrame extends JFrame {
    private JButton[][] buttons;
    private GameLogic gameLogic;
    private PlayerService playerService;
    private Player currentPlayer;
    private JLabel turnLabel;

    public GameFrame(Player player) {
        this.currentPlayer = player;
        this.gameLogic = new GameLogic();
        this.playerService = new PlayerService();
        this.buttons = new JButton[3][3];

        // Window Settings
        setTitle("Tic-Tac-Toe Match");
        setSize(400, 450);
        setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
        setLocationRelativeTo(null);
        setLayout(new BorderLayout());

        // Header status bar
        turnLabel = new JLabel("Your Turn (X)", SwingConstants.CENTER);
        turnLabel.setFont(new Font("Arial", Font.BOLD, 16));
        turnLabel.setBorder(BorderFactory.createEmptyBorder(10, 0, 10, 0));
        add(turnLabel, BorderLayout.NORTH);

        // 3x3 Grid Panel for Buttons
        JPanel gridPanel = new JPanel(new GridLayout(3, 3, 5, 5));
        gridPanel.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));

        // Create buttons and add them to grid
        for (int row = 0; row < 3; row++) {
            for (int col = 0; col < 3; col++) {
                final int r = row;
                final int c = col;
                buttons[row][col] = new JButton("");
                buttons[row][col].setFont(new Font("Arial", Font.BOLD, 40));
                buttons[row][col].setFocusPainted(false);

                // Handle button clicks
                buttons[row][col].addActionListener(new ActionListener() {
                    @Override
                    public void actionPerformed(ActionEvent e) {
                        handlePlayerMove(r, c);
                    }
                });

                gridPanel.add(buttons[row][col]);
            }
        }
        add(gridPanel, BorderLayout.CENTER);
    }

    private void handlePlayerMove(int row, int col) {
        // 1. Check if the cell is valid and empty
        if (gameLogic.makeMove(row, col, gameLogic.getPlayerSymbol())) {
            buttons[row][col].setText(String.valueOf(gameLogic.getPlayerSymbol()));
            buttons[row][col].setForeground(Color.BLUE);

            // 2. Check if player won
            if (gameLogic.checkWin(gameLogic.getPlayerSymbol())) {
                endGame("win", "Congratulations! You won!");
                return;
            }

            // 3. Check for a Draw
            if (gameLogic.isBoardFull()) {
                endGame("draw", "It's a draw!");
                return;
            }

            // 4. Computer's Turn
            turnLabel.setText("Computer's Turn (O)...");
            int[] compMove = gameLogic.makeComputerMove();
            if (compMove != null) {
                int cr = compMove[0];
                int cc = compMove[1];
                buttons[cr][cc].setText(String.valueOf(gameLogic.getComputerSymbol()));
                buttons[cr][cc].setForeground(Color.RED);
            }

            // 5. Check if computer won
            if (gameLogic.checkWin(gameLogic.getComputerSymbol())) {
                endGame("loss", "The computer won! Better luck next time.");
                return;
            }

            // 6. Check for a Draw again after computer move
            if (gameLogic.isBoardFull()) {
                endGame("draw", "It's a draw!");
                return;
            }

            turnLabel.setText("Your Turn (X)");
        }
    }

    private void endGame(String outcome, String message) {
        JOptionPane.showMessageDialog(this, message);
        
        // Push the update safely into your database!
        playerService.updateStatistics(currentPlayer, outcome);

        // Go back to the updated Main Menu dashboard
        new MainMenuFrame(currentPlayer).setVisible(true);
        dispose();
    }
}
